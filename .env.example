# -----------------------------------------------------------------------------
# SaqBol.kz local Docker environment
# Copy to .env before running docker compose.
# -----------------------------------------------------------------------------

APP_ENV=local
NODE_ENV=production
TZ=Asia/Qyzylorda

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
PUBLIC_WEB_PORT=3000
WORKSPACE_WEB_PORT=3001
API_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# PostgreSQL
# For Docker Compose use host "postgres".
# For running API directly on Windows, use localhost instead.
# -----------------------------------------------------------------------------
POSTGRES_DB=saqbol
POSTGRES_USER=saqbol_app
POSTGRES_PASSWORD=saqbol_password
DATABASE_URL=postgresql://saqbol_app:saqbol_password@postgres:5432/saqbol?schema=public

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=saqbol_redis_password
REDIS_URL=redis://:saqbol_redis_password@redis:6379

# -----------------------------------------------------------------------------
# JWT / Sessions
# Replace in staging/production.
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=local_access_secret_change_me_64_chars_minimum_1234567890
JWT_REFRESH_SECRET=local_refresh_secret_change_me_64_chars_minimum_1234567890
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# -----------------------------------------------------------------------------
# Frontend / API
# -----------------------------------------------------------------------------
PUBLIC_BASE_URL=http://localhost:3000
WORKSPACE_BASE_URL=http://localhost:3001/workspace
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
API_URL=http://api:4000/api/v1
NEXT_PUBLIC_WORKSPACE_BASE_PATH=/workspace
NEXT_PUBLIC_AI_ENABLED=true
API_CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3001,http://localhost:3001/workspace

# -----------------------------------------------------------------------------
# File storage for MVP
# API stores uploads in /uploads and exports in /exports Docker volumes.
# S3-compatible storage can be added later without changing API contracts.
# -----------------------------------------------------------------------------
UPLOADS_ROOT=/uploads
EXPORTS_ROOT=/exports

# -----------------------------------------------------------------------------
# AI
# If OPENAI_API_KEY is empty, API uses safe mock mode.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
AI_LOG_RAW_PROMPTS=false

# -----------------------------------------------------------------------------
# Security / logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
ENABLE_AUDIT_LOGGING=true
RELEASE_VERSION=local
COMMIT_SHA=local
