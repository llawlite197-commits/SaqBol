generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Healthcheck {
  id        String   @id @default(uuid()) @db.Uuid
  status    String   @default("ok")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("healthchecks")
}
